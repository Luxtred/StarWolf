{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "starwolfv1",
  "version": "0.1.0",
  "identifier": "com.luxtred.starwolfv1",
  "build": {
    "frontendDist": "../src"
  },
"app": {
  "withGlobalTauri": true,
    "windows": [
      {
        "title": "StarWolf",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "/home/luxtred/Música/**"
        ]
      }
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}